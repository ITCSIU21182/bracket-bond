# Copy to app/.env.local (gitignored) and fill in.

# --- Public (safe to expose in the client bundle) ---
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=EbYmsXdALmF4GHY5JQT2Rv5fqC2Nws2qFcnh4B1QXE3U
# id of the market created on that cluster (see scripts/replay or your deploy)
NEXT_PUBLIC_MARKET_ID=1

# --- Server-only (NEVER prefix with NEXT_PUBLIC — stays out of the client) ---
# Powers the /api/pundit chat route (server-side only). Without it the pundit
# replies with a 501 and the rest of the app works normally.
# SECURITY: use a freshly-rotated key. Never commit .env.local.
OPENAI_API_KEY=sk-proj-...
