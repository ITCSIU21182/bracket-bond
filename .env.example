# --- TxLINE ---
# Mainnet API base: https://txline.txodds.com   |  Devnet API base: https://txline-dev.txodds.com
TXLINE_BASE_URL=https://txline-dev.txodds.com
# Free World-Cup tier: SERVICE_LEVEL 1 = 60s delay (any net), 12 = real-time (mainnet only)
TXLINE_SERVICE_LEVEL=1
# Activation (after you send the on-chain SERVICE_LEVEL subscription tx — see docs/worldcup):
TXLINE_TXSIG=
TXLINE_SIGNATURE=            # base64 wallet signature over the activation message
TXLINE_LEAGUES=              # comma-separated league ids (World Cup)

# Txoracle program (holds the daily Merkle roots + validateStat):
TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J   # devnet
# mainnet: 9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA

# --- Solana / Anchor ---
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
# Set after `anchor keys sync` (replaces the placeholder in Anchor.toml / lib.rs)
BRACKET_BOND_PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS
