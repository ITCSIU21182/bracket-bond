# --- TxLINE (free World Cup tier; devnet) ---
# host — mainnet https://txline.txodds.com | devnet https://txline-dev.txodds.com
TXLINE_BASE_URL=https://txline-dev.txodds.com
# TxL token mint for the on-chain subscription (Token-2022). Devnet:
TXLINE_TOKEN_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
# Txoracle program (daily Merkle roots + validateStatV2 + subscribe). Devnet:
TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
# mainnet: program 9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA · TxL mint Zhw9TVKp68a1QrftncMSd6ELXKDtpVMNuMGr1jNwdeL
# The subscribe + activate flow runs from ANCHOR_WALLET (a local keypair) — see scripts/txline/index.ts.

# --- Solana / Anchor ---
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
# Fixed program id (committed keypair in keys/ — no `anchor keys sync` needed)
BRACKET_BOND_PROGRAM_ID=EbYmsXdALmF4GHY5JQT2Rv5fqC2Nws2qFcnh4B1QXE3U

# --- Autonomous keeper (scripts/agent/keeper.ts, pnpm keeper) ---
# Comma-separated market ids to watch + settle permissionlessly. ANCHOR_WALLET
# is the keeper — it need NOT be the oracle authority (that's the point).
KEEPER_MARKET_IDS=1
KEEPER_POLL_MS=30000
